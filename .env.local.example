# Copy this file to .env.local and fill in real values for local development.
# Production values must be set in the Vercel dashboard under
# Settings → Environment Variables (Production scope).
# Never commit real secrets — .env.local is in .gitignore.

# Resend API key — used by /api/contact to send the contact form to info@neuropharmgeorgia.com
# Get one from https://resend.com (Dashboard → API Keys → Create)
# Format: re_XXXXXXXXXXXXXXXXXXXXXX
RESEND_API_KEY=re_replace_with_real_key
